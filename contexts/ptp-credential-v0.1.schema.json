{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://preferencelayer.io/schema/ptp-credential-v0.1.schema.json",
  "title": "PTP Preference Credential v0.1",
  "description": "Frozen v0.1 schema for a Preference Transport Protocol credential. A W3C Verifiable Credential 2.0 envelope whose credentialSubject carries a sparse preference graph. Authoritative field names follow docs/protocol-spec.md sec 3.",
  "type": "object",
  "required": ["@context", "type", "issuer", "issuanceDate", "credentialSubject"],
  "properties": {
    "@context": {
      "type": "array",
      "minItems": 2,
      "contains": { "const": "https://www.w3.org/ns/credentials/v2" },
      "allOf": [
        { "contains": { "const": "https://preferencelayer.io/context/v1" } }
      ],
      "items": { "type": "string" }
    },
    "type": {
      "type": "array",
      "minItems": 2,
      "allOf": [
        { "contains": { "const": "VerifiableCredential" } },
        { "contains": { "const": "PreferenceCredential" } }
      ],
      "items": { "type": "string" }
    },
    "issuer": { "$ref": "#/$defs/did" },
    "issuanceDate": { "type": "string", "format": "date-time" },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "preferenceGraph"],
      "properties": {
        "id": { "$ref": "#/$defs/did" },
        "preferenceGraph": { "$ref": "#/$defs/preferenceGraph" }
      },
      "additionalProperties": true
    },
    "proof": { "$ref": "#/$defs/proof" }
  },
  "additionalProperties": true,
  "$defs": {
    "did": {
      "type": "string",
      "description": "A Decentralized Identifier. v0.1 accepts any DID method (sec 8 Q1 unresolved); did:key is RECOMMENDED.",
      "pattern": "^did:[a-z0-9]+:.+"
    },
    "preferenceGraph": {
      "type": "object",
      "required": [
        "category",
        "version",
        "attributeNodes",
        "edges",
        "updateCount",
        "privacyBudgetConsumed",
        "lastUpdated"
      ],
      "properties": {
        "category": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "const": "0.1" },
        "attributeNodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/attributeNode" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        },
        "contextConditioners": {
          "type": "array",
          "items": { "$ref": "#/$defs/contextConditioner" }
        },
        "updateCount": { "type": "integer", "minimum": 0 },
        "privacyBudgetConsumed": { "type": "number", "minimum": 0 },
        "lastUpdated": { "type": "string" },
        "coldStartPrior": { "type": "string" }
      },
      "additionalProperties": false
    },
    "attributeNode": {
      "type": "object",
      "required": ["id", "weight", "confidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "weight": { "type": "number", "minimum": -1, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "embedding": {
          "type": "array",
          "items": { "type": "number" }
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["source", "target", "weight"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "weight": { "type": "number", "minimum": -1, "maximum": 1 },
        "contextKey": { "type": "string" }
      },
      "additionalProperties": false
    },
    "contextConditioner": {
      "type": "object",
      "required": ["contextKey", "activeNodes"],
      "properties": {
        "contextKey": { "type": "string", "minLength": 1 },
        "activeNodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suppressedNodes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "proof": {
      "type": "object",
      "required": ["type", "verificationMethod", "proofValue"],
      "properties": {
        "type": { "type": "string", "const": "Ed25519Signature2020" },
        "created": { "type": "string" },
        "verificationMethod": { "type": "string" },
        "proofPurpose": { "type": "string" },
        "proofValue": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
